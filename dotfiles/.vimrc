set nocompatible
syntax on

set nu
set rnu
set background=dark
set encoding=utf-8

filetype plugin indent on

set tabstop=4
set shiftwidth=4
set expandtab
set autoindent

set nowrap
set breakindent
set textwidth=0
set wrapmargin=0

set backspace=indent,eol,start
set hidden
set wildmenu
set laststatus=2
set scrolloff=5

set incsearch
set hlsearch
set ignorecase
set smartcase
