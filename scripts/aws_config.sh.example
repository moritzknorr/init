declare -A SUBNET_IDS=(
  [aventa]="subnet-xxxxxxxxxxxxxxxxx"
  [aventa-prod]="subnet-xxxxxxxxxxxxxxxxx"
  [aventapharm]="subnet-xxxxxxxxxxxxxxxxx"
  [agencio-dev]="subnet-xxxxxxxxxxxxxxxxx"
)

declare -A SECURITY_GROUP_IDS=(
